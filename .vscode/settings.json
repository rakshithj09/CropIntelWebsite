{
  // Use the repo venv by default. Change this path if you create a different venv.
  "python.defaultInterpreterPath": ".venv/bin/python",

  // Tailwind/PostCSS directives are valid - suppress CSS unknown at-rule warnings
  "css.lint.unknownAtRules": "ignore",
  "less.lint.unknownAtRules": "ignore",
  "scss.lint.unknownAtRules": "ignore",

  // Temporarily reduce missing-import noise from Pylance for modules handled in Docker
  // (set to "error" to re-enable). We installed most deps into .venv; TensorFlow can
  // be installed later in a 3.11 venv if needed.
  "python.analysis.diagnosticSeverityOverrides": {
    "reportMissingImports": "warning"
  }
}
