{
  "name": "cropintel-web",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev -H 0.0.0.0 -p 3050",
    "dev:clean": "rm -rf .next && next dev -H 0.0.0.0 -p 3050",
    "build": "next build",
    "build:hosting": "NEXT_OUTPUT_EXPORT=true next build",
    "deploy:hosting": "npm run build:hosting && firebase deploy --only hosting",
    "start": "next start -H 0.0.0.0 -p 3050",
    "lint": "next lint"
  },
  "dependencies": {
    "lucide-react": "^0.562.0",
    "next": "^14.0.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "autoprefixer": "^10.4.0",
    "eslint": "^8.0.0",
    "eslint-config-next": "^14.0.0",
    "firebase-tools": "^15.20.0",
    "postcss": "^8.4.0",
    "tailwindcss": "^3.3.0",
    "typescript": "^5.0.0"
  }
}
